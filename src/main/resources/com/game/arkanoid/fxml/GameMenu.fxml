<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane stylesheets="@../css/game.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.game.arkanoid.controller.MenuController">

    <children>
        <VBox alignment="CENTER"
              spacing="18.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              styleClass="menu-root">

            <padding>
                <Insets top="120.0"/>
            </padding>

            <children>
                <ImageView fitHeight="204.0"
                           fitWidth="582.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png"/>
                    </image>
                </ImageView>

                <Button fx:id="startButton"
                        text="Start Game"
                        onAction="#onStartGame"
                        defaultButton="true"
                        styleClass="menu-button"/>

                <Button fx:id="settingsButton"
                        text="Settings"
                        onAction="#onOpenSettings"
                        styleClass="menu-button"/>

                <Button fx:id="exitButton"
                        text="Exit"
                        onAction="#onExit"
                        cancelButton="true"
                        styleClass="menu-button"/>
            </children>
        </VBox>
    </children>
</AnchorPane>
